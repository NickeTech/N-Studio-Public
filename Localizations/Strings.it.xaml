    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale16">Scala di grigi 16 colori</s:String>
    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale16.Info">Palette fissa 4 bpp con 16 voci in scala di grigi</s:String>
    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale">Scala di grigi 256 colori</s:String>
    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale.Info">Palette fissa 8 bpp con 256 voci in scala di grigi</s:String>
