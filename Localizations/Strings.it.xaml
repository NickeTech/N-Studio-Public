    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.SystemDefault8BppPalette">Palette predefinita 8 bpp di sistema</s:String>
    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.SystemDefault8BppPalette.Info">Palette fissa 8 bpp che include i colori 'web-safe' e la trasparenza</s:String>
