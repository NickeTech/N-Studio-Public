    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale">Grijstinten 256 kleuren</s:String>
    <s:String x:Key="S.Preset.Encoder.Gif.Quantizer.Predefined.Grayscale.Info">Vast 8 bpp-palette met 256 grijstinten</s:String>
